# Iron Realm — environment template
# Copy this file to .env.local and fill in real values from your Supabase project.
# .env.local is gitignored; never commit it.
#
# Where to find these:
#   Supabase Dashboard → your project → Project Settings → API
#   - Project URL    → REACT_APP_SUPABASE_URL
#   - anon / public  → REACT_APP_SUPABASE_ANON_KEY
# Do NOT use the service_role key on the client.
#
# Restart `npm start` after editing — Create React App reads env vars on boot.

REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key
